<Window x:Class="ReadCity.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай город - Авторизация" Height="280" Width="380"
        Icon="/Resources/icon.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Авторизация:" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" />
        <TextBlock Grid.Row="1" Text="Логин:"/>
        <TextBox Grid.Row="2" x:Name="LoginBox" Margin="0,0,0,10" TabIndex="0" Padding="5"/>

        <TextBlock Grid.Row="3" Text="Пароль:" />
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" TabIndex="1" Padding="5"/>

        <TextBlock Grid.Row="5" x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" VerticalAlignment="Top" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Войти" Click="Login_Click" IsDefault="True" Width="90" TabIndex="2" />
            <Button Content="Отмена" Click="Cancel_Click" IsCancel="True" Width="90" TabIndex="3" />
        </StackPanel>
    </Grid>
</Window>
